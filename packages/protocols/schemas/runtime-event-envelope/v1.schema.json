{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.dromio.dev/runtime-event-envelope/v1.schema.json",
  "title": "Dromio Runtime Event Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "source", "subject", "type", "time", "data"],
  "properties": {
    "schemaVersion": {
      "const": "dromio.runtime-event-envelope.v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9]*)+$"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "traceId": {
      "type": "string",
      "minLength": 1
    },
    "correlationId": {
      "type": "string",
      "minLength": 1
    },
    "data": {
      "type": "object",
      "additionalProperties": true
    }
  }
}

