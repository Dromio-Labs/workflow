{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.dromio.dev/artifact-decision/v1.schema.json",
  "title": "Dromio Artifact Decision Payload v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactId", "roomId", "deciderParticipantId", "decision", "decidedAt"],
  "properties": {
    "schemaVersion": {
      "const": "dromio.artifact-decision.v1"
    },
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "roomId": {
      "type": "string",
      "minLength": 1
    },
    "deciderParticipantId": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": ["approved", "rejected"]
    },
    "note": {
      "type": "string"
    },
    "decidedAt": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}

