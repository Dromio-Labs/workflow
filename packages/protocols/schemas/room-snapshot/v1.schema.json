{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.dromio.dev/room-snapshot/v1.schema.json",
  "title": "Dromio Room Snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "roomId", "status", "participants", "messages", "hands", "approvals", "artifacts", "decisions", "updatedAt"],
  "properties": {
    "schemaVersion": {
      "const": "dromio.room-snapshot.v1"
    },
    "roomId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["created", "live", "ended", "archived"]
    },
    "participants": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["participantId", "kind", "displayName", "status"],
        "properties": {
          "participantId": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": ["human", "agent", "system"]
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["invited", "joined", "left"]
          }
        }
      }
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "hands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["handId", "participantId", "status", "raisedAt"],
        "properties": {
          "handId": {
            "type": "string",
            "minLength": 1
          },
          "participantId": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["open", "resolved"]
          },
          "raisedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}

