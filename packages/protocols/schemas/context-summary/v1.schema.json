{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://schemas.dromio.dev/context-summary/v1.schema.json", "title": "Dromio Context Summary v1",
  "type": "object", "additionalProperties": false,
  "required": ["schemaVersion", "id", "threadId", "coversThroughTurnOrdinal", "sourceItemRevisionIds", "content", "status", "modelId", "promptVersion", "createdAt"],
  "properties": {
    "schemaVersion": { "const": "dromio.context-summary.v1" }, "id": { "type": "string", "minLength": 1 }, "threadId": { "type": "string", "minLength": 1 }, "coversFromTurnOrdinal": { "type": "integer", "minimum": 1 }, "coversThroughTurnOrdinal": { "type": "integer", "minimum": 1 }, "sourceItemRevisionIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1, "uniqueItems": true }, "content": { "type": "array", "items": { "$ref": "https://schemas.dromio.dev/thread-item/v1.schema.json#/$defs/contentPart" } }, "kind": { "enum": ["leaf", "hierarchical"] }, "requestedBy": { "enum": ["automatic", "manual"] }, "sourceSummaryIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }, "replacesSummaryIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }, "status": { "enum": ["generating", "ready", "invalidated", "failed"] }, "modelId": { "type": "string", "minLength": 1 }, "promptVersion": { "type": "string", "minLength": 1 }, "failureCode": { "type": "string", "minLength": 1 }, "createdAt": { "type": "string", "format": "date-time" }
  }
}
