{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.dromio.dev/usage-record/v1.schema.json",
  "title": "Dromio Usage Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "tenantId", "applicationId", "correlationId", "runId", "attemptId", "providerId", "status", "occurredAt"],
  "properties": {
    "schemaVersion": { "const": "dromio.usage-record.v1" },
    "id": { "type": "string", "minLength": 1 },
    "tenantId": { "type": "string", "minLength": 1 },
    "applicationId": { "type": "string", "minLength": 1 },
    "correlationId": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "attemptId": { "type": "string", "minLength": 1 },
    "providerId": { "type": "string", "minLength": 1 },
    "threadId": { "type": "string" },
    "turnId": { "type": "string" },
    "modelId": { "type": "string" },
    "inputTokens": { "type": "integer", "minimum": 0 },
    "cachedInputTokens": { "type": "integer", "minimum": 0 },
    "outputTokens": { "type": "integer", "minimum": 0 },
    "reasoningTokens": { "type": "integer", "minimum": 0 },
    "toolId": { "type": "string" },
    "toolUnits": { "type": "number", "minimum": 0 },
    "amount": { "type": "string" },
    "currency": { "type": "string" },
    "reconcilesUsageRecordIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "status": { "enum": ["estimated", "final", "reconciled"] },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
