{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.dromio.dev/command-receipt/v1.schema.json",
  "title": "Dromio Command Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "commandId", "resource", "replayed"],
  "properties": {
    "schemaVersion": { "const": "dromio.command-receipt.v1" },
    "commandId": { "type": "string", "minLength": 1 },
    "resource": {},
    "applicationSequence": { "type": "integer", "minimum": 1 },
    "userSequence": { "type": "integer", "minimum": 1 },
    "threadSequence": { "type": "integer", "minimum": 1 },
    "replayed": { "type": "boolean" }
  }
}
