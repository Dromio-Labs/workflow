{
  "name": "@dromio/workflow-kernel",
  "version": "0.1.7",
  "dromio": {
    "stability": "beta"
  },
  "private": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun build src/index.ts --target=node --format=cjs --outfile dist/index.cjs",
    "check": "bun run typecheck && bun run test && bun run build",
    "prepack": "bun run build",
    "test": "bun test src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "cron-parser": "5.5.0"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dromio-Labs/workflow.git",
    "directory": "packages/workflow/kernel"
  },
  "publishConfig": {
    "access": "public"
  }
}
