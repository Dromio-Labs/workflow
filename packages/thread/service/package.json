{
  "name": "@dromio/thread-service",
  "version": "0.2.1",
  "dromio": {
    "stability": "beta"
  },
  "private": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@dromio/protocols": "workspace:*",
    "ajv": "8.18.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "bun run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test src",
    "check": "bun run typecheck && bun run test && bun run build"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dromio-Labs/workflow.git",
    "directory": "packages/thread/service"
  },
  "publishConfig": {
    "access": "public"
  }
}
