{
  "name": "dromio-workflow",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/execution",
    "packages/protocols",
    "packages/room/protocol",
    "packages/sdk",
    "packages/shell/chat-shell-ui",
    "packages/thread/service",
    "packages/trigger",
    "packages/workflow/canvas-protocol",
    "packages/workflow/kernel"
  ],
  "scripts": {
    "build": "bun run --cwd packages/sdk build",
    "check": "bun run --cwd packages/sdk check && bun run --cwd packages/sdk verify:package",
    "local-registry": "bun scripts/build-local-registry.ts",
    "test": "bun test packages/sdk",
    "typecheck": "bun run --cwd packages/sdk check"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "24.13.2",
    "typescript": "5.9.3"
  },
  "overrides": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tar": "7.5.16"
  },
  "trustedDependencies": [],
  "license": "Apache-2.0"
}
